{
  "name": "deadline-demon",
  "version": "0.1.1",
  "description": "Cross-CLI hook tool that arms session deadlines and nudges AI agents to finish on time (optional hard enforcement)",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bengHak/DeadlineDemon.git"
  },
  "homepage": "https://github.com/bengHak/DeadlineDemon#readme",
  "bugs": {
    "url": "https://github.com/bengHak/DeadlineDemon/issues"
  },
  "keywords": [
    "claude",
    "codex",
    "grok",
    "ai-agent",
    "deadline",
    "hooks"
  ],
  "bin": {
    "deadline-demon": "dist/cli.js"
  },
  "files": [
    ".claude-plugin",
    ".codex-plugin",
    "dist/cli.d.ts",
    "dist/cli.js",
    "dist/core",
    "dist/formatters",
    "dist/hooks",
    "dist/install.d.ts",
    "dist/install.js",
    "hooks",
    "plugin",
    "skills",
    "templates"
  ],
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "test": "npm run build && node --test dist/tests/**/*.test.js",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.2"
  }
}
